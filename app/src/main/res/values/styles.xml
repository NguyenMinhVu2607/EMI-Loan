<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTypography" parent="">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>

    <style name="TextTitleExtraLarge" parent="AppTypography">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
    </style>

    <style name="TextHeader" parent="AppTypography">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextCardTitle" parent="AppTypography">
        <item name="android:textSize">@dimen/_13sdp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextDescription" parent="AppTypography">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#808080</item>
    </style>

    <style name="TextBottomNav" parent="AppTypography">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="TextButton" parent="AppTypography">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>